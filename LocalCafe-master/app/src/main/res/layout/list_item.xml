<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/the_parent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:background="@color/main_light"
    android:elevation="5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/relativeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_light"
        android:padding="8dp">

        <TextView
            android:id="@+id/table_number"
            style="@style/LightBlue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corner_btn"
            android:width="25dp"
            android:height="45dp"
            android:padding="5dp"
            android:text="1"
            android:textColor="@color/black"
            android:textSize="25sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/orders"
            style="@style/LightBlue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/border"
            android:minWidth="10dp"
            android:minHeight="10dp"
            android:padding="5dp"
            android:text="قهوة"
            android:textColor="@color/main"
            android:textSize="25sp"
            app:layout_constraintEnd_toStartOf="@+id/table_number"
            app:layout_constraintTop_toTopOf="@+id/table_number" />

        <TextView
            android:id="@+id/numbers"
            style="@style/LightBlue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textDirection="rtl"
            android:layout_marginEnd="8dp"
            android:background="@drawable/border"
            android:minWidth="10dp"
            android:minHeight="10dp"
            android:padding="5dp"
            android:text="5"
            android:textColor="@color/main"
            android:textSize="25sp"
            app:layout_constraintEnd_toStartOf="@+id/orders"
            app:layout_constraintTop_toTopOf="@+id/orders" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corner_btn"
            android:padding="5dp"
            android:text="ازالة"
            android:textColor="@color/black"
            android:textSize="25sp"
            app:layout_constraintEnd_toStartOf="@+id/numbers"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/numbers" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>